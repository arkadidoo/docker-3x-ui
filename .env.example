# =============================================================================
# docker-3x-ui — Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# Docker image.
# Pin a specific tag instead of 'latest' in production, e.g.:
#   ghcr.io/mhsanaei/3x-ui:2.4.5
XUI_IMAGE=ghcr.io/mhsanaei/3x-ui:latest

# Docker container name (used in docker restart / logs commands)
CONTAINER_NAME=3xui_app

# Host port exposed for the web panel.
# The container always listens on 2053 internally.
PANEL_PORT=2057

# -----------------------------------------------------------------------------
# SSL Certificates
# -----------------------------------------------------------------------------

# Absolute host path to the certificate directory.
# It is mounted read-only as /root/cert inside the container.
CERT_DIR=/root/cert

# Subdirectory within CERT_DIR where acme.sh installs the cert files.
# Use "ip" for IP-based certs (default) or a domain name, e.g. "vpn.example.com".
# The panel will look for:
#   /root/cert/<CERT_SUBDOMAIN>/fullchain.pem
#   /root/cert/<CERT_SUBDOMAIN>/privkey.pem
CERT_SUBDOMAIN=ip

# Email address for acme.sh Let's Encrypt account registration.
# Required by setup_ssl.sh.
ACME_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# 3x-ui / Xray Settings
# -----------------------------------------------------------------------------

# Disable VMESS AEAD forced mode (recommended for broad client compatibility)
XRAY_VMESS_AEAD_FORCED=false

# Enable built-in Fail2ban (blocks IPs after repeated failed login attempts)
XUI_ENABLE_FAIL2BAN=true

# -----------------------------------------------------------------------------
# Log Rotation
# -----------------------------------------------------------------------------

LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
